---
import testimonialsData from '../data/testimonials.json';
---

<!--
  Testimonials — Embla Carousel (embla-carousel)
  ───────────────────────────────────────────────
  One testimonial card per viewport on every screen size.
  Powered by Embla Carousel: the most popular, actively maintained,
  mobile-first open-source carousel library.

  Features:
  • Smooth touch/pointer drag on mobile and desktop
  • Infinite loop (wraps first ↔ last)
  • Dot indicator synced to the active slide
  • No horizontal overflow visible outside the section
-->
<section id="testimonials" class="testimonials-section scene-section scene-scroll">
  <div class="container">
    <h2 class="text-reveal">What Clients Say</h2>
    <p class="section-intro text-reveal">
      Testimonials from corporate events and weddings across San Diego and beyond.
    </p>

    <div class="testimonials-carousel-wrap">
      <!-- Embla viewport (overflow hidden applied by JS) -->
      <div class="embla" id="testimonials-embla">
        <div class="embla__container">
          {testimonialsData.map((testimonial) => (
            <article class="embla__slide testimonial-card card-reveal" role="listitem">
              <div class="stars" aria-label={`${testimonial.rating} out of 5 stars`}>
                {[...Array(testimonial.rating)].map(() => (
                  <span class="star" aria-hidden="true">★</span>
                ))}
              </div>
              <p class="testimonial-text">"{testimonial.reviewBody}"</p>
              <div class="testimonial-author">
                <p class="author-name">{testimonial.author}</p>
                {testimonial.company && <p class="author-company">{testimonial.company}</p>}
                <p class="event-type">{testimonial.eventType === 'corporate' ? 'Corporate Event' : 'Wedding'}</p>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- Dot navigation -->
      <div class="carousel-dots" id="testimonials-dots" aria-label="Testimonial navigation">
        {testimonialsData.map((_, i) => (
          <button
            class={`carousel-dot${i === 0 ? ' active' : ''}`}
            data-index={i}
            aria-label={`Go to testimonial ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    padding: 0;
    /* Prevent Embla from expanding the document width */
    overflow: hidden;
  }

  .testimonials-carousel-wrap {
    position: relative;
    margin-top: 1.5rem;
    width: 100%;
  }

  /* ── Embla viewport ── */
  .embla {
    overflow: hidden;
    width: 100%;
    padding: 0 0.75rem;
    box-sizing: border-box;
  }

  /* ── Embla track ── */
  .embla__container {
    display: flex;
    touch-action: pan-y pinch-zoom;
  }

  /* ── Slide — one full-width card per view ── */
  .embla__slide {
    flex: 0 0 calc(100% - 0.5rem);
    min-width: 0;
    margin-left: 0.5rem;
  }

  /* ── Testimonial card ── */
  .testimonial-card {
    background: rgba(20, 20, 20, 0.82);
    border: 1px solid rgba(201, 169, 89, 0.3);
    border-radius: 8px;
    padding: 1.5rem;
    transition: border-color 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .testimonial-card:hover {
    border-color: rgba(201, 169, 89, 0.65);
  }

  /* Card enter animation */
  .card-reveal {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .card-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Stars ── */
  .stars {
    color: var(--color-gold, #c9a959);
    font-size: 1rem;
    letter-spacing: 0.2rem;
    flex-shrink: 0;
  }

  .star {
    display: inline-block;
  }

  /* ── Testimonial text ── */
  .testimonial-text {
    color: rgba(255, 255, 255, 0.9);
    font-family: 'EB Garamond', serif;
    font-size: 1rem;
    line-height: 1.55;
    font-style: italic;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  /* ── Author block ── */
  .testimonial-author {
    border-top: 1px solid rgba(201, 169, 89, 0.2);
    padding-top: 0.75rem;
    flex-shrink: 0;
  }

  .author-name {
    color: var(--color-gold, #c9a959);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.15rem;
    line-height: 1.2;
  }

  .author-company {
    color: rgba(255, 255, 255, 0.65);
    font-family: 'EB Garamond', serif;
    font-size: 0.85rem;
    margin-bottom: 0.15rem;
    line-height: 1.2;
  }

  .event-type {
    color: rgba(201, 169, 89, 0.8);
    font-family: 'EB Garamond', serif;
    font-size: 0.82rem;
    font-style: italic;
    margin: 0;
    line-height: 1.2;
  }

  /* ── Navigation dots ── */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 1.25rem;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid rgba(201, 169, 89, 0.5);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .carousel-dot.active {
    background: var(--color-gold, #c9a959);
    border-color: var(--color-gold, #c9a959);
  }

  /* ── Desktop ── */
  @media (min-width: 768px) {
    .testimonial-text {
      -webkit-line-clamp: 6;
      font-size: 1.05rem;
    }
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel';

  const emblaNode = document.getElementById('testimonials-embla');
  const dotsContainer = document.getElementById('testimonials-dots');
  if (emblaNode && dotsContainer) {
    const embla = EmblaCarousel(emblaNode, { loop: false, align: 'start' });
    const dots = Array.from(dotsContainer.querySelectorAll('.carousel-dot'));

    function syncDots() {
      const idx = embla.selectedScrollSnap();
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
    }

    embla.on('select', syncDots);
    embla.on('reInit', syncDots);

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => embla.scrollTo(i));
    });

    // ── Card reveal via IntersectionObserver ──
    const cards = Array.from(emblaNode.querySelectorAll('.testimonial-card'));
    const sectionEl = document.getElementById('testimonials');
    if (sectionEl && 'IntersectionObserver' in window) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            cards.forEach((c) => c.classList.add('visible'));
            obs.disconnect();
          }
        });
      }, { threshold: 0.2 });
      obs.observe(sectionEl);
    } else if (sectionEl) {
      cards.forEach((c) => c.classList.add('visible'));
    }
  }
</script>

