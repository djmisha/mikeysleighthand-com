---
import faqData from '../data/faq.json';
---

<!--
  FAQ — Embla Carousel (embla-carousel) with ParlourOverlay answers
  ─────────────────────────────────────────────────────────────────────────
  Displays all FAQ questions as full-width cards in a single-card carousel.
  Clicking/tapping a card opens the full question + answer in the site's
  reusable ParlourOverlay.

  Powered by Embla Carousel: the most popular, actively maintained,
  mobile-first open-source carousel library.

  Features:
  • One card per viewport on mobile and desktop
  • Smooth touch/pointer drag
  • Infinite loop
  • Dot indicator synced to active slide
  • No horizontal overflow outside the section
-->
<section id="faq" class="faq-section scene-section scene-scroll">
  <div class="container">
    <h2 class="text-reveal">Frequently Asked Questions</h2>
    <p class="section-intro text-reveal">
      Common questions about booking a San Diego magician for corporate events and weddings.
    </p>

    <div class="faq-carousel-wrap">
      <!-- Embla viewport -->
      <div class="embla" id="faq-embla">
        <div class="embla__container">
          {faqData.map((item, index) => (
            <div class="embla__slide" role="listitem">
              <button
                class="faq-card card-reveal"
                data-faq-index={index}
                data-answer={item.answer}
                aria-label={`FAQ: ${item.question}`}
              >
                <span class="faq-card-num">0{index + 1}</span>
                <span class="faq-card-question">{item.question}</span>
                <span class="faq-card-cta" aria-hidden="true">Read Answer ›</span>
              </button>
            </div>
          ))}
        </div>
      </div>

      <!-- Dot navigation -->
      <div class="carousel-dots faq-dots" id="faq-dots" aria-label="FAQ navigation">
        {faqData.map((_, i) => (
          <button
            class={`carousel-dot${i === 0 ? ' active' : ''}`}
            data-index={i}
            aria-label={`FAQ question ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 0;
    /* Prevent Embla from expanding the document width */
    overflow: hidden;
  }

  .faq-carousel-wrap {
    margin-top: 1.5rem;
    width: 100%;
  }

  /* ── Embla viewport ── */
  .embla {
    overflow: hidden;
    width: 100%;
  }

  /* ── Embla track ── */
  .embla__container {
    display: flex;
    touch-action: pan-y pinch-zoom;
  }

  /* ── Slide — one full-width card per view ── */
  .embla__slide {
    flex: 0 0 100%;
    min-width: 0;
  }

  /* ── FAQ card ── */
  .faq-card {
    width: 100%;
    background: rgba(20, 20, 20, 0.72);
    border: 1px solid rgba(201, 169, 89, 0.3);
    border-radius: 6px;
    padding: 1.5rem 1.25rem 1.25rem;
    cursor: pointer;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    min-height: 160px;
    transition: border-color 0.25s ease, background 0.25s ease;
    /* Reset button defaults */
    -webkit-appearance: none;
    font-family: inherit;
  }

  .faq-card:hover,
  .faq-card:focus-visible {
    border-color: rgba(201, 169, 89, 0.7);
    background: rgba(28, 28, 28, 0.9);
    outline: none;
  }

  .faq-card:focus-visible {
    box-shadow: 0 0 0 2px rgba(201, 169, 89, 0.5);
  }

  /* Card reveal animation */
  .card-reveal {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .card-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Card number ── */
  .faq-card-num {
    display: block;
    font-family: var(--font-display, 'Cinzel'), serif;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: rgba(201, 169, 89, 0.55);
  }

  /* ── Card question ── */
  .faq-card-question {
    display: block;
    flex: 1;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-gold, #c9a959);
    line-height: 1.35;
  }

  /* ── Read-more hint ── */
  .faq-card-cta {
    display: block;
    font-family: var(--font-body, 'EB Garamond'), serif;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.05em;
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  .faq-card:hover .faq-card-cta,
  .faq-card:focus-visible .faq-card-cta {
    color: rgba(201, 169, 89, 0.75);
  }

  /* ── Navigation dots ── */
  .faq-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid rgba(201, 169, 89, 0.5);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .carousel-dot.active {
    background: var(--color-gold, #c9a959);
    border-color: var(--color-gold, #c9a959);
  }

  /* ── Desktop ── */
  @media (min-width: 768px) {
    .faq-card {
      min-height: 180px;
    }

    .faq-card-question {
      font-size: 1.2rem;
    }
  }
</style>

<!-- FAQ overlay content styles (injected into ParlourOverlay body) -->
<style is:global>
  .faq-overlay-content {
    max-width: 720px;
    width: 90%;
    margin: 0 auto;
    padding: 20px;
    text-align: left;
  }

  .faq-overlay-content .faq-overlay-num {
    font-family: var(--font-display, 'Cinzel'), serif;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: rgba(201, 169, 89, 0.55);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .faq-overlay-content h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    color: var(--color-gold, #c9a959);
    font-weight: 400;
    line-height: 1.25;
    margin-bottom: 1.5rem;
  }

  .faq-overlay-content p {
    font-family: 'EB Garamond', serif;
    font-size: 1.2rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.88);
  }
</style>

<script>
  import EmblaCarousel from 'embla-carousel';

  const emblaNode = document.getElementById('faq-embla');
  const dotsContainer = document.getElementById('faq-dots');

  if (emblaNode && dotsContainer) {
    const embla = EmblaCarousel(emblaNode, { loop: true, align: 'start' });
    const dots = Array.from(dotsContainer.querySelectorAll('.carousel-dot'));

    function syncDots() {
      const idx = embla.selectedScrollSnap();
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
    }

    embla.on('select', syncDots);
    embla.on('reInit', syncDots);

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => embla.scrollTo(i));
    });

    // ── Card click → open ParlourOverlay with full answer ──
    const cards = Array.from(emblaNode.querySelectorAll('.faq-card'));

    cards.forEach((card) => {
      card.addEventListener('click', () => {
        const qEl = card.querySelector('.faq-card-question');
        const numEl = card.querySelector('.faq-card-num');
        const question = qEl ? qEl.textContent.trim() : '';
        const numText = numEl ? numEl.textContent.trim() : '';
        const answer = card.dataset.answer || '';

        const html =
          '<div class="faq-overlay-content">' +
            '<p class="faq-overlay-num">' + numText + '</p>' +
            '<h3>' + escapeHtml(question) + '</h3>' +
            '<p>' + escapeHtml(answer) + '</p>' +
          '</div>';

        if (window.ParlourOverlay) {
          window.ParlourOverlay.open(html);
        }
      });
    });

    function escapeHtml(str) {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    // ── Card reveal via IntersectionObserver ──
    const sectionEl = document.getElementById('faq');
    if (sectionEl && 'IntersectionObserver' in window) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            cards.forEach((c) => c.classList.add('visible'));
            obs.disconnect();
          }
        });
      }, { threshold: 0.15 });
      obs.observe(sectionEl);
    } else if (sectionEl) {
      cards.forEach((c) => c.classList.add('visible'));
    }
  }
</script>

