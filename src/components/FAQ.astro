---
import faqData from '../data/faq.json';
---

<!--
  FAQ — horizontal snap-scroll card carousel with ParlourOverlay answers
  ─────────────────────────────────────────────────────────────────────────
  Displays all FAQ questions as compact cards in a single-row horizontal
  carousel.  Clicking/tapping a card opens the full question + answer in
  the site's reusable ParlourOverlay (same overlay used for the contact form
  and navigation menu).

  This design fits the entire FAQ in one full-screen scene on both mobile
  and desktop, consistent with the scroll-hijack single-scene layout.

  Mobile:  ~1.6 cards visible, swipe to see more.
  Desktop: ~3 cards visible, scroll or click dots.
-->
<section id="faq" class="faq-section scene-section scene-scroll">
  <div class="container">
    <h2 class="text-reveal">Frequently Asked Questions</h2>
    <p class="section-intro text-reveal">
      Common questions about booking a San Diego magician for corporate events and weddings.
    </p>

    <div class="faq-carousel-wrap">
      <div class="faq-carousel" id="faq-carousel" role="list">
        {faqData.map((item, index) => (
          <button
            class="faq-card card-reveal"
            role="listitem"
            data-faq-index={index}
            data-answer={item.answer}
            aria-label={`FAQ: ${item.question}`}
          >
            <span class="faq-card-num">0{index + 1}</span>
            <span class="faq-card-question">{item.question}</span>
            <span class="faq-card-cta" aria-hidden="true">Read Answer ›</span>
          </button>
        ))}
      </div>

      <!-- Dot navigation -->
      <div class="carousel-dots faq-dots" id="faq-dots" aria-label="FAQ navigation">
        {faqData.map((_, i) => (
          <button
            class={`carousel-dot${i === 0 ? ' active' : ''}`}
            data-index={i}
            aria-label={`FAQ question ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 0;
  }

  /* ── Carousel wrap ── */
  .faq-carousel-wrap {
    margin-top: 1.5rem;
  }

  /* ── Carousel track ── */
  .faq-carousel {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.5rem;
    touch-action: pan-x;
  }

  .faq-carousel::-webkit-scrollbar {
    display: none;
  }

  /* ── FAQ card ── */
  .faq-card {
    flex: 0 0 calc(80% - 0.5rem);    /* mobile: ~1.3 visible */
    scroll-snap-align: start;
    background: rgba(20, 20, 20, 0.72);
    border: 1px solid rgba(201, 169, 89, 0.3);
    border-radius: 6px;
    padding: 1.5rem 1.25rem 1.25rem;
    cursor: pointer;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    min-height: 160px;
    transition: border-color 0.25s ease, background 0.25s ease;
    /* Reset button defaults */
    -webkit-appearance: none;
    font-family: inherit;
  }

  .faq-card:hover,
  .faq-card:focus-visible {
    border-color: rgba(201, 169, 89, 0.7);
    background: rgba(28, 28, 28, 0.9);
    outline: none;
  }

  .faq-card:focus-visible {
    box-shadow: 0 0 0 2px rgba(201, 169, 89, 0.5);
  }

  /* Card reveal animation (triggered by IntersectionObserver) */
  .card-reveal {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .card-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Staggered delays */
  .faq-card:nth-child(1).card-reveal  { transition-delay: 0.30s; }
  .faq-card:nth-child(2).card-reveal  { transition-delay: 0.36s; }
  .faq-card:nth-child(3).card-reveal  { transition-delay: 0.42s; }
  .faq-card:nth-child(4).card-reveal  { transition-delay: 0.48s; }
  .faq-card:nth-child(5).card-reveal  { transition-delay: 0.54s; }
  .faq-card:nth-child(6).card-reveal  { transition-delay: 0.60s; }
  .faq-card:nth-child(7).card-reveal  { transition-delay: 0.66s; }
  .faq-card:nth-child(8).card-reveal  { transition-delay: 0.72s; }

  /* ── Card number ── */
  .faq-card-num {
    display: block;
    font-family: var(--font-display, 'Cinzel'), serif;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: rgba(201, 169, 89, 0.55);
  }

  /* ── Card question ── */
  .faq-card-question {
    display: block;
    flex: 1;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-gold, #c9a959);
    line-height: 1.35;
  }

  /* ── Read-more hint ── */
  .faq-card-cta {
    display: block;
    font-family: var(--font-body, 'EB Garamond'), serif;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.05em;
    flex-shrink: 0;
    transition: color 0.2s ease;
  }

  .faq-card:hover .faq-card-cta,
  .faq-card:focus-visible .faq-card-cta {
    color: rgba(201, 169, 89, 0.75);
  }

  /* ── Navigation dots (shared with testimonials via .carousel-dot) ── */
  .faq-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid rgba(201, 169, 89, 0.5);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .carousel-dot.active {
    background: var(--color-gold, #c9a959);
    border-color: var(--color-gold, #c9a959);
  }

  /* ── Desktop: 3 cards visible ── */
  @media (min-width: 768px) {
    .faq-card {
      flex: 0 0 calc(30% - 0.67rem);
      min-height: 180px;
    }

    .faq-card-question {
      font-size: 1.2rem;
    }
  }
</style>

<!-- FAQ overlay content styles (injected into ParlourOverlay body) -->
<style is:global>
  .faq-overlay-content {
    max-width: 720px;
    width: 90%;
    margin: 0 auto;
    padding: 20px;
    text-align: left;
  }

  .faq-overlay-content .faq-overlay-num {
    font-family: var(--font-display, 'Cinzel'), serif;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: rgba(201, 169, 89, 0.55);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .faq-overlay-content h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    color: var(--color-gold, #c9a959);
    font-weight: 400;
    line-height: 1.25;
    margin-bottom: 1.5rem;
  }

  .faq-overlay-content p {
    font-family: 'EB Garamond', serif;
    font-size: 1.2rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.88);
  }
</style>

<script>
  /**
   * FAQ carousel: dot sync, card-reveal animations, and overlay trigger.
   *
   * When a card is clicked, window.ParlourOverlay.open() is called with the
   * full question + answer HTML.  ParlourOverlay handles close button, ESC key,
   * and backdrop click — no additional logic needed here.
   */
  (function () {
    // ── Inline FAQ data for overlay content ──
    // This data is passed from the Astro build-time JSON so there is no
    // runtime fetch required.
    var faqItems = document.querySelectorAll('.faq-card');
    var carousel  = document.getElementById('faq-carousel');
    var dotsContainer = document.getElementById('faq-dots');

    if (!faqItems.length || !carousel || !dotsContainer) return;

    var dots  = Array.from(dotsContainer.querySelectorAll('.carousel-dot'));
    var cards = Array.from(faqItems);

    // ── Active-dot tracking ──
    var rafId = null;
    function updateActiveDot() {
      if (!cards.length) return;
      var cardWidth = cards[0].getBoundingClientRect().width;
      var gap = 16; // matches 1rem gap
      var idx = Math.round(carousel.scrollLeft / (cardWidth + gap));
      idx = Math.max(0, Math.min(idx, dots.length - 1));
      dots.forEach(function (d, i) { d.classList.toggle('active', i === idx); });
    }

    carousel.addEventListener('scroll', function () {
      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(updateActiveDot);
    }, { passive: true });

    // ── Dot click → scroll to card ──
    dots.forEach(function (dot, i) {
      dot.addEventListener('click', function () {
        var card = cards[i];
        if (!card) return;
        card.scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
      });
    });

    // ── Card click → open ParlourOverlay with full answer ──
    cards.forEach(function (card) {
      card.addEventListener('click', function () {
        var idx = parseInt(card.dataset.faqIndex, 10);
        var qEl = card.querySelector('.faq-card-question');
        var numEl = card.querySelector('.faq-card-num');
        var question = qEl ? qEl.textContent.trim() : '';
        var numText  = numEl ? numEl.textContent.trim() : '';

        // Pull the answer from the data-answer attribute on the card button
        var answer = card.dataset.answer || '';

        var html =
          '<div class="faq-overlay-content">' +
            '<p class="faq-overlay-num">' + numText + '</p>' +
            '<h3>' + escapeHtml(question) + '</h3>' +
            '<p>' + escapeHtml(answer) + '</p>' +
          '</div>';

        if (window.ParlourOverlay) {
          window.ParlourOverlay.open(html);
        }
      });
    });

    function escapeHtml(str) {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    // ── Card reveal via IntersectionObserver ──
    var sectionEl = document.getElementById('faq');
    if (sectionEl && 'IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            cards.forEach(function (c) { c.classList.add('visible'); });
            obs.disconnect();
          }
        });
      }, { threshold: 0.15 });
      obs.observe(sectionEl);
    } else if (sectionEl) {
      cards.forEach(function (c) { c.classList.add('visible'); });
    }
  })();
</script>

